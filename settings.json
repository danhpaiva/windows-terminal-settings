{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "actions": [],
    "alwaysOnTop": false,
    "centerOnLaunch": true,
    "copyFormatting": "none",
    "copyOnSelect": true,
    "defaultProfile": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
    "disableAnimations": false,
    "keybindings": [
        // Divide a tela verticalmente (lado a lado)
        {
            "command": {
                "action": "splitPane",
                "split": "vertical"
            },
            "keys": "alt+shift+plus"
        },
        // Divide a tela horizontalmente (cima e baixo)
        {
            "command": {
                "action": "splitPane",
                "split": "horizontal"
            },
            "keys": "alt+shift+-"
        },
        // Fecha o painel atual (sem fechar a aba toda se houver outros)
        {
            "command": "closePane",
            "keys": "ctrl+shift+w"
        },
        // Navega entre os painéis abertos usando Alt + Setas
        {
            "command": {
                "action": "moveFocus",
                "direction": "left"
            },
            "keys": "alt+left"
        },
        {
            "command": {
                "action": "moveFocus",
                "direction": "right"
            },
            "keys": "alt+right"
        },
        {
            "command": {
                "action": "moveFocus",
                "direction": "up"
            },
            "keys": "alt+up"
        },
        {
            "command": {
                "action": "moveFocus",
                "direction": "down"
            },
            "keys": "alt+down"
        }
    ],
    "newTabMenu": [
        {
            "type": "remainingProfiles"
        }
    ],
    "profiles": {
        "defaults": {
            "colorScheme": "Hyper",
            "cursorColor": "#FFFFFF",
            "cursorShape": "filledBox",
            "font": {
                "face": "Cascadia Mono",
                "size": 14
            },
            "opacity": 80,
            "padding": "10",
            "useAcrylic": true
        },
        "list": [
            {
                "commandline": "powershell.exe -NoLogo",
                "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
                "name": "PowerShell",
                "startingDirectory": "%USERPROFILE%"
            },
            {
